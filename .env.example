# Environment variables for Lakshya Presentation Studio

# Optional: Gemini API Key for AI presentation generation
# By default, preview handles this transparently if not provided
GEMINI_API_KEY=

# Cloudinary Database connection (Requested by user)
# Use server-side variables only to keep secrets hidden:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
